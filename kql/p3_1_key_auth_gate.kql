// P3.1 gate -- must return ZERO rows for 7 consecutive days before
// disableLocalAuth=true is allowed to merge.
AzureDiagnostics
| where ResourceProvider == "MICROSOFT.COGNITIVESERVICES" and Category == "RequestResponse"
| where TimeGenerated > ago(7d)
| where ResultSignature startswith "2"
| where isempty(column_ifexists("identity_claim_oid_g", ""))
| summarize keyOnlyCalls = count(),
            distinctCallers = dcount(CallerIPAddress)
  by bin(TimeGenerated, 1d)
