// AIF_TokensByTeam(timeRange:timespan)
// column_ifexists() keeps this resolvable before any RequestResponse data lands.
let mapping = AIF_CallerToTeam();
AzureDiagnostics
| where ResourceProvider == "MICROSOFT.COGNITIVESERVICES" and Category == "RequestResponse"
| where TimeGenerated > ago(timeRange)
| extend oid   = column_ifexists("identity_claim_oid_g", "")
| extend appid = column_ifexists("identity_claim_appid_g", "")
| extend principalId = case(isnotempty(oid), oid, isnotempty(appid), appid, "api-key")
| lookup kind=leftouter mapping on principalId
| extend team  = case(isnotempty(team), team, principalId == "api-key", "api-key-unattributed", "aad-unattributed")
| extend usage = parse_json(column_ifexists("properties_s", "{}")).usage
| summarize requests = count(),
            input  = sum(toint(usage.prompt_tokens)),
            cached = sum(toint(usage.prompt_tokens_details.cached_tokens)),
            output = sum(toint(usage.completion_tokens))
  by team, bin(TimeGenerated, 1d)
